{
    "name": "mai-space-de/faq",
    "description": "TYPO3 FAQ extension providing accordion view, category tabs and search filter widget.",
    "type": "typo3-cms-extension",
    "license": "GPL-2.0-or-later",
    "authors": [
        {
            "name": "mai.space",
            "email": "info@mai.space",
            "role": "Developer"
        }
    ],
    "require": {
        "typo3/cms-core": "^12.4 || ^13.0",
        "typo3/cms-extbase": "^12.4 || ^13.0",
        "typo3/cms-fluid": "^12.4 || ^13.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0"
    },
    "autoload": {
        "psr-4": {
            "MaiSpace\\Faq\\": "Classes/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "MaiSpace\\Faq\\Tests\\": "Tests/"
        }
    },
    "extra": {
        "typo3/cms": {
            "extension-key": "faq"
        }
    }
}
