{
  "name": "maispace/mai-faq",
  "description": "TYPO3 FAQ extension providing accordion view, category tabs and search filter widget.",
  "type": "typo3-cms-extension",
  "license": "GPL-2.0-or-later",
  "authors": [
    {
      "name": "mai.space",
      "email": "info@mai.space",
      "role": "Developer"
    }
  ],
  "require": {
    "php": "^8.2",
    "typo3/cms-core": "^13.4",
    "typo3/cms-extbase": "^13.4",
    "typo3/cms-fluid": "^13.4"
  },
  "require-dev": {
    "phpunit/phpunit": "^10.0"
  },
  "autoload": {
    "psr-4": {
      "Maispace\\MaiFaq\\": "Classes/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Maispace\\MaiFaq\\Tests\\": "Tests/"
    }
  },
  "extra": {
    "typo3/cms": {
      "extension-key": "mai_faq"
    },
    "branch-alias": {
      "dev-main": "13.0.x-dev"
    }
  }
}
